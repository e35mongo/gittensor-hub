GITHUB_USERNAME=your-github-login
GITHUB_PAT=
GITHUB_PATS=ghp_xxx,ghp_yyy

PORT=12074

# Optional: omit to auto-generate on first run, or set a 32+ character secret.
# SESSION_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

ADMIN_GITHUB_LOGINS=your-github-login

# Local only — skips GitHub sign-in (ignored when NODE_ENV=production).
# Set both so the server gate and the header UI stay in sync.
# DEV_BYPASS_AUTH=1
# NEXT_PUBLIC_DEV_BYPASS_AUTH=1
